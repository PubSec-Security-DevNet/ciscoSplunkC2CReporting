<check_type:"Windows" version:"2">
<custom_item>
    type: AUDIT_POWERSHELL
    description: "C2C WMI Powershell Memory Information"
    value_type: POLICY_TEXT
    powershell_args: "Get-WmiObject Win32_ComputerSystem | select {[int]($_.TotalPhysicalMemory /1GB)} | Format-List -Property *"
    value_data:""
    only_show_cmd_output: YES
    check_type: CHECK_REGEX
</custom_item>
</check_type>