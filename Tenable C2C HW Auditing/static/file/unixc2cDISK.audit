##
# This audit serves as an example that could assist in custom audit creation.
#
# Requires modification of the sudoers file to allow commands to run without password input
# Ubuntu:
#   USERNAME ALL=NOPASSWD:{COMMAND},/usr/sbin/dmidecode, /usr/sbin/lshw
# RHEL
#   USERNAME ALL=(ALL) NOPASSWD: /usr/sbin/dmidecode, /usr/bin/lshw
#

<check_type:"Unix">

<if>
    <condition type:"OR">
        <custom_item>
            system      : "Linux"
            type        : CMD_EXEC
            description : "Disk Space"
            cmd         : "df -h /"
            expect      : "(.*)$"
		</custom_item>
    </condition>
    <then>
        <report type:"PASSED">
            description : "C2C System Disk Information Gathered Successfully"
            show_output : YES
        </report>
    </then>
    <else>
        <report type:"FAILED">
            description : "C2C System Disk Information Incomplete or Missing"
            show_output : YES
        </report>
    </else>
</if>

</check_type>