<check_type:"Windows" version:"2">
<custom_item>
    type: AUDIT_POWERSHELL
    description: "C2C WMI Powershell Network Interface Information"
    value_type: POLICY_TEXT
    powershell_args: "Get-WmiObject Win32_NetworkAdapter | where-object {$_.PhysicalAdapter -eq 'True'} | where-object {$_.NetConnectionStatus -lt 4} |Format-List -Property ProductName, MACAddress, Manufacturer"
    value_data:""
    only_show_cmd_output: YES
    check_type: CHECK_REGEX
</custom_item>
</check_type>